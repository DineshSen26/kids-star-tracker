SECRET_KEY=replace-with-a-long-random-secret
# Use Neon's pooled connection string in production (hostname contains -pooler)
DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
APP_NAME=CheerSteps
APP_TAGLINE=Tiny Steps, Big Celebrations
APP_BASE_URL=https://cheersteps.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://cheersteps.com/auth/google/callback
PREFERRED_URL_SCHEME=https
SEED_DEMO_DATA=true
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo123
# SMTP for forgot-password emails (Gmail, SendGrid, Mailgun, etc.)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=CheerSteps <noreply@cheersteps.com>
MAIL_USE_TLS=true
MAIL_TIMEOUT=10
